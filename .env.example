# Публичный URL сайта (канонический для SEO и JSON-LD). На Vercel: https://ваш-проект.vercel.app
NEXT_PUBLIC_SITE_URL=https://localhost:3000

# Яндекс.Метрика (номер счётчика). Заглушка 00000000 — скрипт не грузится; на Vercel задайте реальный ID
NEXT_PUBLIC_YM_ID=00000000

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# ID чата или канала (например: -1001234567890 или 1234567890)
TELEGRAM_CHAT_ID=
